{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "types": ["node"],
    "paths": {
      "@gridstorm/dataflow-core":         ["../packages/core/src/index.ts"],
      "@gridstorm/dataflow-canvas":       ["../packages/canvas/src/index.ts"],
      "@gridstorm/dataflow-canvas/react": ["../packages/canvas/src/integrations/react.tsx"]
    }
  },
  "include": ["src/**/*", "vite.config.ts"]
}
