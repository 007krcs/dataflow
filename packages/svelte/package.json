{
  "name": "@dataflow/svelte",
  "version": "0.3.0",
  "description": "DataFlow Svelte 5 stores and runes for real-time streaming data",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev":   "tsup --watch"
  },
  "dependencies": {
    "@dataflow/core": "workspace:*"
  },
  "peerDependencies": {
    "svelte": ">=5.0.0"
  },
  "devDependencies": {
    "tsup":       "^8.3.0",
    "typescript": "^5.6.0",
    "svelte":     "^5.0.0"
  }
}
