{
  "name": "@gridstorm/dataflow-vue",
  "version": "0.3.1",
  "homepage": "https://dataflow.tekivex.com",
  "description": "DataFlow Vue 3 composables for real-time streaming data",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev":   "tsup --watch"
  },
  "dependencies": {
    "@gridstorm/dataflow-core": "workspace:*"
  },
  "peerDependencies": {
    "vue": ">=3.3.0"
  },
  "devDependencies": {
    "tsup":       "^8.3.0",
    "typescript": "^5.6.0",
    "vue":        "^3.4.0"
  }
}
