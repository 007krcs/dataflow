{
  "compilerOptions": {
    "target":           "ES2022",
    "module":           "ESNext",
    "moduleResolution": "Bundler",
    "strict":           true,
    "declaration":      true,
    "skipLibCheck":     true,
    "noUnusedLocals":   true,
    "noUnusedParameters": true,
    "outDir":           "dist"
  },
  "include": ["src"]
}
